# ============================================================
#  LabLabee – Challenge 3: ODA Canvas
#  Environment Configuration
#  Edit this file to customize your lab environment
# ============================================================

# ── Cluster Settings ──────────────────────────────────────
ODA_CLUSTER_NAME=oda-lab
ODA_NAMESPACE=canvas
ODA_CANVAS_VERSION=1.1.0

# ── Port Mappings (host ports) ────────────────────────────
ODA_CANVAS_UI_PORT=3000
ODA_PRODUCTCATALOG_PORT=8081
ODA_PARTYMANAGEMENT_PORT=8082

# ── Memory Limits (per container) ─────────────────────────
# Reduce if you have less than 4GB available
ODA_COMPONENT_MEMORY_LIMIT=512m
ODA_COMPONENT_MEMORY_REQUEST=256m
ODA_CANVAS_MEMORY_LIMIT=256m

# ── ODA Canvas Options ────────────────────────────────────
# Set to "true" to enable Keycloak (requires +1GB RAM)
ODA_SECURITY_ENABLED=false
# Set to "true" to enable Prometheus monitoring
ODA_MONITORING_ENABLED=false

# ── Lab Data ──────────────────────────────────────────────
ODA_SEED_DATA=true
ODA_SEED_DATA_FILE=data/seed-data.json
