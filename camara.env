# ============================================================
#  LabLabee – Challenge 5: Open Gateway and CAMARA
#  Environment Configuration
# ============================================================

# Cluster
CLUSTER_NAME=camara-lab
NAMESPACE=camara

# API ports (host-side port-forwards)
QOD_PORT=8083
DEVICE_LOCATION_PORT=8084
SIM_SWAP_PORT=8085
UI_PORT=3000

# CAMARA API base paths
QOD_BASE_PATH=/camara/quality-on-demand/v0
DEVICE_LOCATION_BASE_PATH=/camara/device-location/v0
SIM_SWAP_BASE_PATH=/camara/sim-swap/v0

# Mock server resource limits (reduce if < 4GB RAM)
MOCK_MEMORY_LIMIT=256Mi
MOCK_MEMORY_REQUEST=128Mi
MOCK_CPU_LIMIT=250m
MOCK_CPU_REQUEST=100m

# UI
UI_MEMORY_LIMIT=128Mi
UI_MEMORY_REQUEST=64Mi

# Seed data defaults
DEFAULT_MSISDN=+33612345678
DEFAULT_QOS_PROFILE=QOS_E
DEFAULT_SESSION_DURATION=3600
